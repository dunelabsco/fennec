# Fennec docker-compose environment.
#
# Copy this file to `.env` and fill in only the keys/tokens you actually
# use. Any unset variable simply means "that integration is disabled."
#
# Anything sensitive lives ONLY in this file (or in `~/.fennec/config.toml`
# inside the container's /data volume); it never gets baked into the image.

# ---- Tracing ----------------------------------------------------------------

# Default log level for the entire process. `RUST_LOG=fennec=debug` for
# noisier; `RUST_LOG=warn` for quieter. Per-module overrides also work:
# RUST_LOG=fennec=info,fennec::collective=debug
RUST_LOG=info

# ---- LLM providers ----------------------------------------------------------

# Pick the one your `provider.name` in config.toml refers to. Only the
# matching key needs to be set; others can stay empty/omitted.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# KIMI_API_KEY=sk-kimi-...

# ---- Collective (Plurum) -----------------------------------------------------

# Optional. Without this the collective layer falls back to local-only
# mode (search hits local memory + local cache, no remote publish).
# PLURUM_API_KEY=plurum_...

# ---- Channel auth ------------------------------------------------------------
#
# Channel tokens are normally read from config.toml (run `fennec onboard`).
# Setting them as env vars is supported for ephemeral / CI-style runs but
# the wizard-written config is the recommended shape.
